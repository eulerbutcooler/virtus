# App
APP_ENV=development

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=60s

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=virtus
DB_PASSWORD=random
DB_NAME=virtus
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=redis
REDIS_DB=0

# JWT
JWT_SECRET=long-random-string-here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
